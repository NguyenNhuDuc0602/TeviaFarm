@model TeviaFarm.Models.Post
@{
    ViewData["Title"] = "Tạo bài viết";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Community" asp-action="Index">Cộng đồng</a></li>
        <li class="breadcrumb-item active" aria-current="page">Tạo bài viết</li>
    </ol>
</nav>

<div class="d-flex align-items-end justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h2 class="page-title mb-1">Tạo bài viết mới</h2>
        <div class="text-muted small">Chia sẻ kinh nghiệm, mẹo chăn nuôi hoặc câu hỏi của bạn.</div>
    </div>
</div>

<div class="summary-card p-3 p-lg-4">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="form-floating mb-2">
            <input asp-for="Title" class="form-control" placeholder="Tiêu đề" />
            <label asp-for="Title">Tiêu đề</label>
        </div>
        <div class="mb-3">
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="form-floating mb-2">
            <textarea asp-for="Content" class="form-control" placeholder="Nội dung" style="height: 160px;"></textarea>
            <label asp-for="Content">Nội dung</label>
        </div>
        <div class="mb-3">
            <span asp-validation-for="Content" class="text-danger"></span>
        </div>

        <div class="form-floating mb-2">
            <input asp-for="ImageUrl" class="form-control" placeholder="Đường dẫn hình ảnh" />
            <label asp-for="ImageUrl">Đường dẫn hình ảnh (nếu có)</label>
        </div>
        <div class="mb-3">
            <span asp-validation-for="ImageUrl" class="text-danger"></span>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-success">
                <i class="bi bi-send me-1"></i>Gửi bài
            </button>
            <a asp-action="Index" class="btn btn-outline-success">
                <i class="bi bi-arrow-left me-1"></i>Quay lại
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}