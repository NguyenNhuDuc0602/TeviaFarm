@model TeviaFarm.Models.Post
@{
    ViewData["Title"] = "Chi tiết bài viết";
}

<div class="card">
    <div class="card-body">
        <h3 class="card-title">@Model.Title</h3>
        <p class="card-text">@Model.Content</p>
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Title" />
        }
        <p class="mt-3 text-muted">Ngày tạo: @Model.CreatedDate</p>
        <a asp-action="Index" class="btn btn-link">← Quay lại danh sách</a>
    </div>
</div>

