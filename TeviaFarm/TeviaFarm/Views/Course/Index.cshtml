@model IEnumerable<TeviaFarm.Models.Course>
@{
    ViewData["Title"] = "Khóa học";
}

<div class="pb-4" style="min-height: 420px;">
    <h2>Khóa học nuôi heo trà xanh</h2>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var c in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@c.Title</h5>
                        <p class="card-text text-truncate">@c.Description</p>
                        <p class="fw-bold text-success">@c.Price.ToString("N0") đ</p>
                        <div class="mt-auto">
                            <a asp-action="Details" asp-route-id="@c.CourseId" class="btn btn-outline-success btn-sm">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>