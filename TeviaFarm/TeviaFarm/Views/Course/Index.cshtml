@model IEnumerable<TeviaFarm.Models.Course>
@{
    ViewData["Title"] = "Khóa học";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item active" aria-current="page">Khóa học</li>
    </ol>
</nav>

<div class="d-flex align-items-end justify-content-between flex-wrap gap-2 mb-4">
    <div>
        <h2 class="page-title mb-1">Khóa học nuôi heo trà xanh</h2>
        <div class="text-muted small">Học mô hình chăn nuôi sạch và tối ưu vận hành trang trại.</div>
    </div>
</div>

<div class="pb-4" style="min-height: 420px;">
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var c in Model)
        {
            <div class="col">
                <div class="card h-100 card-hover">
                    <div class="card-body d-flex flex-column p-4">
                        <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                            <h5 class="card-title mb-0">@c.Title</h5>
                            <span class="badge bg-success-subtle text-success border border-success-subtle">
                                <i class="bi bi-cash-coin me-1"></i>@c.Price.ToString("N0") đ
                            </span>
                        </div>
                        <p class="card-text text-muted line-clamp-2 mb-3">@c.Description</p>
                        <div class="mt-auto d-grid">
                            <a asp-action="Details" asp-route-id="@c.CourseId" class="btn btn-outline-success btn-sm">
                                <i class="bi bi-eye me-1"></i>Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)">
                    Trước
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)">
                    Sau
                </a>
            </li>
        </ul>
    </nav>
}