@model TeviaFarm.Models.Cart
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="d-flex align-items-end justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h2 class="page-title mb-1">Giỏ hàng</h2>
        <div class="text-muted small">Kiểm tra số lượng và tiến hành thanh toán.</div>
    </div>
</div>

@if (Model == null || Model.Items == null || !Model.Items.Any())
{
    <div class="card card-hover">
        <div class="card-body p-4 p-lg-5 text-center">
            <div class="display-6 mb-2"><i class="bi bi-bag text-success"></i></div>
            <h3 class="h5 page-title mb-2">Giỏ hàng hiện đang trống</h3>
            <p class="text-muted mb-3">Khám phá sản phẩm Tevia Farm và thêm vào giỏ để thanh toán.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-success">
                <i class="bi bi-bag-plus me-1"></i>Đi mua sắm
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="table-card">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-end">Đơn giá</th>
                                <th style="width: 170px;">Số lượng</th>
                                <th class="text-end">Thành tiền</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                var unitPrice = item.Product?.Price ?? 0;
                                <tr data-cart-row data-unit-price="@unitPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                    <td class="fw-semibold">@item.Product?.ProductName</td>
                                    <td class="text-end">@unitPrice.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN")) đ</td>
                                    <td>
                                        <form asp-action="Update" method="post" class="d-flex align-items-center" data-cart-form>
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text"><i class="bi bi-hash"></i></span>
                                                <input type="number"
                                                       name="quantity"
                                                       value="@item.Quantity"
                                                       min="1"
                                                       class="form-control"
                                                       data-qty />
                                            </div>
                                        </form>
                                    </td>
                                    <td class="text-end">
                                        <span class="fw-bold text-success" data-line-total>
                                            @((unitPrice * item.Quantity).ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"))) đ
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <form asp-action="Remove" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="summary-card p-3 p-lg-4 position-sticky" style="top: 110px;">
                <h3 class="h5 page-title mb-3">Tóm tắt</h3>

                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="text-muted">Tổng cộng</span>
                    <span class="fw-bold fs-5 text-success" data-cart-total>
                        @Model.Items.Sum(i => (i.Product?.Price ?? 0) * i.Quantity).ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN")) đ
                    </span>
                </div>

                <div class="text-muted small mb-3">
                    <i class="bi bi-truck me-1"></i>Miễn phí vận chuyển cho đơn hàng trên 300.000 đ
                </div>

                <a asp-controller="Order" asp-action="Checkout" class="btn btn-success w-100">
                    <i class="bi bi-credit-card me-1"></i>Tiến hành thanh toán
                </a>

                <a asp-controller="Product" asp-action="Index" class="btn btn-link w-100 mt-2 text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i>Tiếp tục mua sắm
                </a>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        (function () {
          function formatVnd(value) {
            const n = Number(value) || 0;
            return n.toLocaleString('vi-VN') + ' đ';
          }

          function recalc() {
            const rows = document.querySelectorAll('[data-cart-row]');
            let total = 0;

            rows.forEach(row => {
              const unitPrice = parseFloat(row.getAttribute('data-unit-price')) || 0;
              const qtyInput = row.querySelector('[data-qty]');
              const qty = Number(qtyInput?.value) || 0;
              const line = unitPrice * qty;
              total += line;

              const lineEl = row.querySelector('[data-line-total]');
              if (lineEl) lineEl.textContent = formatVnd(line);
            });

            const totalEl = document.querySelector('[data-cart-total]');
            if (totalEl) totalEl.textContent = formatVnd(total);
          }

          document.addEventListener('input', function (e) {
            if (e.target && e.target.matches('[data-qty]')) {
              recalc();
              const form = e.target.closest('[data-cart-form]');
              if (form) {
                clearTimeout(form._debounce);
                form._debounce = setTimeout(function () { form.submit(); }, 600);
              }
            }
          });

          document.addEventListener('change', function (e) {
            if (e.target && e.target.matches('[data-qty]')) {
              const form = e.target.closest('[data-cart-form]');
              if (form) form.submit();
            }
          });

          recalc();
        })();
    </script>
}