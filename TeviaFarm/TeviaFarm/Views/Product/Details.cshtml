@model TeviaFarm.Models.Product
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card product-card">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Url.Content(Model.ImageUrl)" class="card-img-top" alt="@Model.ProductName" />
            }
            else
            {
                <div class="p-5 text-center text-muted">
                    <i class="bi bi-image fs-1"></i>
                    <div class="mt-2">Chưa có hình ảnh</div>
                </div>
            }
        </div>
    </div>
    <div class="col-md-7">
        <h2 class="page-title mb-2">@Model.ProductName</h2>
        <p class="text-muted mb-3">@Model.Description</p>

        <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
            <div class="fw-bold text-success fs-3">@Model.Price.ToString("N0") <span class="fw-semibold fs-6">đ/kg</span></div>
            <span class="badge bg-success-subtle text-success border border-success-subtle">
                <i class="bi bi-box-seam me-1"></i>Tồn kho: @Model.Stock
            </span>
        </div>

        <div class="summary-card p-3 p-lg-4">
            <form asp-controller="Cart" asp-action="Add" method="post" class="row g-2 align-items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@Model.ProductId" />

                <div class="col-12 col-sm-5">
                    <label class="form-label">Số lượng</label>
                    <input type="number" name="quantity" value="1" min="1" class="form-control" />
                </div>
                <div class="col-12 col-sm-7 d-grid">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-bag-plus me-1"></i>Thêm vào giỏ
                    </button>
                </div>
            </form>
        </div>

        <a asp-action="Index" class="btn btn-link px-0 mt-3">
            <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách
        </a>
    </div>
</div>