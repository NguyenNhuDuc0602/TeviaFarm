@model IEnumerable<TeviaFarm.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm";
}

<h2 class="mb-3">Danh sách sản phẩm</h2>

<form method="get" class="row mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control" placeholder="Tìm kiếm sản phẩm..." />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-success">Tìm kiếm</button>
    </div>
</form>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var p in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrEmpty(p.ImageUrl))
                {
                    <img src="@Url.Content(p.ImageUrl)" class="card-img-top" alt="@p.ProductName" />
                }
                else
                {
                    <div class="bg-light border-bottom text-center py-5">
                        <span class="text-muted">Chưa có hình ảnh</span>
                    </div>
                }
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@p.ProductName</h5>
                    <p class="card-text text-truncate">@p.Description</p>
                    <p class="fw-bold text-success">@p.Price.ToString("N0") đ/kg</p>
                    <div class="mt-auto">
                        <a asp-action="Details" asp-route-id="@p.ProductId" class="btn btn-outline-success btn-sm me-2">Xem chi tiết</a>
                        <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                            <input type="hidden" name="productId" value="@p.ProductId" />
                            <button type="submit" class="btn btn-success btn-sm">Thêm vào giỏ</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

