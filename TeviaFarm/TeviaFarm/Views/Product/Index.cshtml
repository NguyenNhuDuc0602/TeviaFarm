@model IEnumerable<TeviaFarm.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string? search = ViewBag.Search as string;
}

<div class="d-flex align-items-end justify-content-between flex-wrap gap-2 mb-4">
    <div>
        <h2 class="page-title mb-1">Sản phẩm</h2>
        @if (!string.IsNullOrWhiteSpace(search))
        {
            <div class="text-muted small">
                Kết quả tìm kiếm cho: <span class="fw-semibold text-success">“@search”</span>
            </div>
        }
        else
        {
            <div class="text-muted small">Chọn sản phẩm phù hợp cho nhu cầu của bạn.</div>
        }
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Không tìm thấy sản phẩm nào.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var p in Model)
        {
            <div class="col">
                <div class="card h-100 product-card card-hover">
                    @if (!string.IsNullOrEmpty(p.ImageUrl))
                    {
                        <img src="@Url.Content(p.ImageUrl)"
                             class="card-img-top"
                             alt="@p.ProductName"
                             loading="lazy" />
                    }

                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <h5 class="card-title mb-1">@p.ProductName</h5>
                            <span class="badge bg-success-subtle text-success border border-success-subtle">
                                @p.Stock sp
                            </span>
                        </div>
                        <p class="card-text text-muted line-clamp-2 mb-2">@p.Description</p>
                        <div class="d-flex align-items-center justify-content-between mt-1">
                            <div class="fw-bold text-success fs-5">@p.Price.ToString("N0") <span class="fw-semibold small">đ/kg</span></div>
                            <i class="bi bi-stars text-success"></i>
                        </div>

                        <div class="mt-auto">
                            <a asp-action="Details"
                               asp-route-id="@p.ProductId"
                               class="btn btn-outline-success btn-sm w-100 mt-3">
                                <i class="bi bi-eye me-1"></i>Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">

                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-search="@search"
                       asp-route-page="@(currentPage - 1)">
                        Trước
                    </a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-search="@search"
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-search="@search"
                       asp-route-page="@(currentPage + 1)">
                        Sau
                    </a>
                </li>

            </ul>
        </nav>
    }
}