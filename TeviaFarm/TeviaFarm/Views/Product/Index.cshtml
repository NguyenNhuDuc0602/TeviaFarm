@model IEnumerable<TeviaFarm.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string? search = ViewBag.Search as string;
}

<h2 class="mb-4">Sản phẩm</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Không tìm thấy sản phẩm nào.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var p in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(p.ImageUrl))
                    {
                        <img src="@Url.Content(p.ImageUrl)"
                             class="card-img-top"
                             alt="@p.ProductName"
                             style="height: 220px; object-fit: cover;" />
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@p.ProductName</h5>
                        <p class="card-text text-truncate">@p.Description</p>
                        <p class="fw-bold text-success">@p.Price.ToString("N0") đ/kg</p>
                        <p class="text-muted">Tồn kho: @p.Stock</p>

                        <div class="mt-auto">
                            <a asp-action="Details"
                               asp-route-id="@p.ProductId"
                               class="btn btn-outline-success btn-sm">
                                Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">

                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-search="@search"
                       asp-route-page="@(currentPage - 1)">
                        Trước
                    </a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-search="@search"
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-search="@search"
                       asp-route-page="@(currentPage + 1)">
                        Sau
                    </a>
                </li>

            </ul>
        </nav>
    }
}