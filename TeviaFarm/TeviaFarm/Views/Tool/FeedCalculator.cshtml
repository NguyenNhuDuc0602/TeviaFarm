@{
    ViewData["Title"] = "Công cụ tính khẩu phần";
}

<h2>Công cụ tính khẩu phần</h2>

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<form asp-action="FeedCalculator" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Số lượng heo</label>
        <input type="number" name="numberOfPigs" class="form-control" min="1" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Khối lượng trung bình mỗi con (kg)</label>
        <input type="number" name="averageWeight" class="form-control" min="0.1" step="0.1" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Giai đoạn phát triển</label>
        <select name="growthStage" class="form-select" required>
            <option value="">-- Chọn giai đoạn --</option>
            <option value="Starter">Heo con</option>
            <option value="Grower">Heo đang lớn</option>
            <option value="Finisher">Heo xuất chuồng</option>
        </select>
    </div>

    <button type="submit" class="btn btn-success">Tính toán</button>
</form>

@if (ViewBag.TotalFeed != null)
{
    <hr />
    <h4>Kết quả</h4>
    <ul class="list-group">
        <li class="list-group-item"><strong>Số lượng heo:</strong> @ViewBag.NumberOfPigs</li>
        <li class="list-group-item"><strong>Khối lượng trung bình:</strong> @ViewBag.AverageWeight kg</li>
        <li class="list-group-item"><strong>Giai đoạn:</strong> @ViewBag.GrowthStage</li>
        <li class="list-group-item"><strong>Tổng lượng cám:</strong> @ViewBag.TotalFeed kg</li>
        <li class="list-group-item"><strong>Bột trà xanh:</strong> @ViewBag.GreenTeaPowder kg</li>
        <li class="list-group-item"><strong>Tỷ lệ trộn:</strong> @ViewBag.MixingRatio</li>
    </ul>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}