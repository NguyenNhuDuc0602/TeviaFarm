@model TeviaFarm.Models.Product
@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<h2>Thêm sản phẩm</h2>

<form asp-action="CreateProduct" method="post" class="row g-3">
    <div class="col-md-6">
        <label asp-for="ProductName" class="form-label">Tên sản phẩm</label>
        <input asp-for="ProductName" class="form-control" />
        <span asp-validation-for="ProductName" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Price" class="form-label">Giá (đ/kg)</label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Stock" class="form-label">Tồn kho</label>
        <input asp-for="Stock" class="form-control" />
        <span asp-validation-for="Stock" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label">Mô tả</label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="ImageUrl" class="form-label">Đường dẫn hình ảnh (ví dụ: ~/images/ten-anh.jpg)</label>
        <input asp-for="ImageUrl" class="form-control" />
        <span asp-validation-for="ImageUrl" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="CategoryId" class="form-label">CategoryId</label>
        <input asp-for="CategoryId" class="form-control" />
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-success">Lưu</button>
        <a asp-action="Products" class="btn btn-link">Hủy</a>
    </div>
</form>

