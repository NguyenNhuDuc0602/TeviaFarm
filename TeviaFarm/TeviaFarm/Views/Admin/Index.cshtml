@model TeviaFarm.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Bảng điều khiển quản trị";
}

@functions {
    public string GetOrderStatusText(string? status)
    {
        return status switch
        {
            "Pending" => "Chờ xử lý",
            "PendingPayment" => "Chờ xác nhận thanh toán",
            "Shipping" => "Đang giao",
            "Completed" => "Hoàn tất",
            "Cancelled" => "Hủy",
            _ => status ?? ""
        };
    }

    public string GetOrderStatusBadgeClass(string? status)
    {
        return status switch
        {
            "Pending" => "bg-warning-subtle text-warning border border-warning-subtle",
            "PendingPayment" => "bg-primary-subtle text-primary border border-primary-subtle",
            "Shipping" => "bg-info-subtle text-info border border-info-subtle",
            "Completed" => "bg-success-subtle text-success border border-success-subtle",
            "Cancelled" => "bg-danger-subtle text-danger border border-danger-subtle",
            _ => "bg-secondary-subtle text-secondary border border-secondary-subtle"
        };
    }
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item active" aria-current="page">Quản trị</li>
    </ol>
</nav>

<div class="d-flex align-items-end justify-content-between flex-wrap gap-2 mb-4">
    <div>
        <h2 class="page-title mb-1">Bảng điều khiển quản trị</h2>
        <div class="text-muted small">Tổng quan hoạt động kinh doanh và quản lý vận hành hệ thống.</div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="summary-card p-3 h-100">
            <div class="text-muted small mb-2">Tổng đơn hàng sản phẩm</div>
            <div class="fw-bold fs-2 text-success">@Model.TotalOrders</div>
            <div class="small text-muted mt-2">Số đơn hàng trong hệ thống</div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="summary-card p-3 h-100">
            <div class="text-muted small mb-2">Doanh thu sản phẩm</div>
            <div class="fw-bold fs-2 text-success">@Model.ProductRevenue.ToString("N0") đ</div>
            <div class="small text-muted mt-2">Chỉ tính đơn đã hoàn tất</div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="summary-card p-3 h-100">
            <div class="text-muted small mb-2">Tổng đơn khóa học</div>
            <div class="fw-bold fs-2 text-primary">@Model.TotalCourseOrders</div>
            <div class="small text-muted mt-2">Số đơn mua khóa học</div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="summary-card p-3 h-100">
            <div class="text-muted small mb-2">Doanh thu khóa học</div>
            <div class="fw-bold fs-2 text-primary">@Model.CourseRevenue.ToString("N0") đ</div>
            <div class="small text-muted mt-2">Chỉ tính đơn đã thanh toán</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-4">
        <div class="summary-card p-3 h-100">
            <div class="text-muted small mb-2">Tổng doanh thu hệ thống</div>
            <div class="fw-bold fs-2 text-dark">@Model.TotalRevenue.ToString("N0") đ</div>
            <div class="small text-muted mt-2">Sản phẩm + khóa học</div>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="summary-card p-3 h-100">
            <div class="text-muted small mb-2">Tổng người dùng</div>
            <div class="fw-bold fs-2 text-dark">@Model.TotalUsers</div>
            <div class="small text-muted mt-2">Tài khoản đã đăng ký</div>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="summary-card p-3 h-100">
            <div class="text-muted small mb-2">Bài viết chờ duyệt</div>
            <div class="fw-bold fs-2 text-warning">@Model.PendingPosts</div>
            <div class="small text-muted mt-2">Cần admin kiểm duyệt</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="table-card h-100">
            <div class="p-3 border-bottom">
                <h3 class="h5 page-title mb-0">Đơn hàng mới nhất</h3>
            </div>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Tổng tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.LatestOrders.Any())
                        {
                            @foreach (var order in Model.LatestOrders)
                            {
                                <tr>
                                    <td class="fw-semibold">#@order.OrderId</td>
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge @GetOrderStatusBadgeClass(order.Status)">
                                            @GetOrderStatusText(order.Status)
                                        </span>
                                    </td>
                                    <td class="text-end fw-semibold text-success">@order.TotalAmount.ToString("N0") đ</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">Chưa có đơn hàng nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="p-3 border-top text-end">
                <a asp-action="Orders" class="btn btn-sm btn-outline-success">Xem tất cả đơn hàng</a>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="table-card h-100">
            <div class="p-3 border-bottom">
                <h3 class="h5 page-title mb-0">Bài viết gần đây</h3>
            </div>

            <div class="list-group list-group-flush">
                @if (Model.LatestPosts.Any())
                {
                    @foreach (var post in Model.LatestPosts)
                    {
                        <div class="list-group-item py-3">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div>
                                    <div class="fw-semibold">@post.Title</div>
                                    <div class="small text-muted">@post.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
                                </div>
                                @if (post.IsApproved)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">Đã duyệt</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle">Chờ duyệt</span>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="p-4 text-center text-muted">Chưa có bài viết nào.</div>
                }
            </div>

            <div class="p-3 border-top text-end">
                <a asp-action="Posts" class="btn btn-sm btn-outline-success">Quản lý bài viết</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 g-lg-4">
    <div class="col-md-6 col-lg-4">
        <a asp-action="Products" class="text-decoration-none">
            <div class="card card-hover h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="text-muted small">Sản phẩm</div>
                            <h3 class="h5 page-title mb-2">Quản lý sản phẩm</h3>
                            <div class="text-muted">Tạo, sửa, xóa và cập nhật tồn kho.</div>
                        </div>
                        <div class="text-success fs-3"><i class="bi bi-box-seam"></i></div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-4">
        <a asp-action="Orders" class="text-decoration-none">
            <div class="card card-hover h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="text-muted small">Đơn hàng</div>
                            <h3 class="h5 page-title mb-2">Quản lý đơn hàng</h3>
                            <div class="text-muted">Theo dõi, xác nhận thanh toán và cập nhật trạng thái giao hàng.</div>
                        </div>
                        <div class="text-success fs-3"><i class="bi bi-receipt"></i></div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-4">
        <a asp-action="CourseOrders" class="text-decoration-none">
            <div class="card card-hover h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="text-muted small">Khóa học</div>
                            <h3 class="h5 page-title mb-2">Quản lý đơn khóa học</h3>
                            <div class="text-muted">Xác nhận thanh toán và mở khóa học cho học viên.</div>
                        </div>
                        <div class="text-success fs-3"><i class="bi bi-credit-card-2-front"></i></div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-4">
        <a asp-action="Users" class="text-decoration-none">
            <div class="card card-hover h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="text-muted small">Tài khoản</div>
                            <h3 class="h5 page-title mb-2">Quản lý người dùng</h3>
                            <div class="text-muted">Xem danh sách người dùng và phân quyền.</div>
                        </div>
                        <div class="text-success fs-3"><i class="bi bi-people"></i></div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-4">
        <a asp-action="Posts" class="text-decoration-none">
            <div class="card card-hover h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="text-muted small">Cộng đồng</div>
                            <h3 class="h5 page-title mb-2">Duyệt bài viết</h3>
                            <div class="text-muted">Duyệt và quản lý nội dung cộng đồng.</div>
                        </div>
                        <div class="text-success fs-3"><i class="bi bi-chat-square-text"></i></div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-4">
        <a asp-action="Courses" class="text-decoration-none">
            <div class="card card-hover h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="text-muted small">Khóa học</div>
                            <h3 class="h5 page-title mb-2">Quản lý khóa học</h3>
                            <div class="text-muted">Tạo khóa học và thêm bài học.</div>
                        </div>
                        <div class="text-success fs-3"><i class="bi bi-mortarboard"></i></div>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>