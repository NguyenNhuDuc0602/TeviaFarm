@model IEnumerable<TeviaFarm.Models.Course>
@{
    ViewData["Title"] = "Quản lý khóa học";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Quản trị</a></li>
        <li class="breadcrumb-item active" aria-current="page">Khóa học</li>
    </ol>
</nav>

<div class="d-flex align-items-end justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h2 class="page-title mb-1">Quản lý khóa học</h2>
        <div class="text-muted small">Tạo khóa học và thêm bài học (video URL).</div>
    </div>
    <a asp-action="CreateCourse" class="btn btn-success">
        <i class="bi bi-plus-lg me-1"></i>Tạo khóa học
    </a>
</div>

@foreach (var c in Model)
{
    <div class="card mb-3 card-hover">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="d-flex align-items-center flex-wrap gap-2">
                        <h5 class="card-title mb-0">@c.Title</h5>
                        <span class="badge bg-success-subtle text-success border border-success-subtle">
                            <i class="bi bi-cash-coin me-1"></i>@c.Price.ToString("N0") đ
                        </span>
                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">
                            <i class="bi bi-collection-play me-1"></i>@(c.Lessons?.Count ?? 0) bài
                        </span>
                    </div>
                    <p class="card-text mt-2 text-muted mb-0">@c.Description</p>
                </div>
                <div class="text-end">
                    <a asp-action="CreateLesson" asp-route-courseId="@c.CourseId" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-plus-circle me-1"></i>Thêm bài học
                    </a>
                </div>
            </div>

            <div class="mt-3">
                <div class="fw-semibold mb-2">Bài học</div>
                @if (c.Lessons == null || !c.Lessons.Any())
                {
                    <div class="text-muted">Chưa có bài học.</div>
                }
                else
                {
                    <ul class="list-group mt-2">
                        @foreach (var l in c.Lessons)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span class="d-flex align-items-center gap-2">
                                    <i class="bi bi-play-circle text-success"></i>
                                    <span>@l.Title</span>
                                </span>
                                <span class="text-muted small text-truncate" style="max-width: 44ch;">@l.VideoUrl</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
}

