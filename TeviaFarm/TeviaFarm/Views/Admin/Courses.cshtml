@model IEnumerable<TeviaFarm.Models.Course>
@{
    ViewData["Title"] = "Quản lý khóa học";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Quản lý khóa học</h2>
    <a asp-action="CreateCourse" class="btn btn-success">Tạo khóa học</a>
</div>

@foreach (var c in Model)
{
    <div class="card mb-3 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h5 class="card-title mb-1">@c.Title</h5>
                    <div class="text-muted">@c.Price.ToString("N0") đ</div>
                    <p class="card-text mt-2">@c.Description</p>
                </div>
                <div class="text-end">
                    <a asp-action="CreateLesson" asp-route-courseId="@c.CourseId" class="btn btn-sm btn-outline-primary">
                        Thêm bài học
                    </a>
                </div>
            </div>

            <div class="mt-3">
                <strong>Bài học:</strong>
                @if (c.Lessons == null || !c.Lessons.Any())
                {
                    <div class="text-muted">Chưa có bài học.</div>
                }
                else
                {
                    <ul class="list-group mt-2">
                        @foreach (var l in c.Lessons)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@l.Title</span>
                                <span class="text-muted small">@l.VideoUrl</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
}

