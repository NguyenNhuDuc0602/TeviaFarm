@model IEnumerable<TeviaFarm.Models.Post>
@{
    ViewData["Title"] = "Quản lý bài viết cộng đồng";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Quản trị</a></li>
        <li class="breadcrumb-item active" aria-current="page">Bài viết</li>
    </ol>
</nav>

<div class="d-flex align-items-end justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h2 class="page-title mb-1">Quản lý bài viết cộng đồng</h2>
        <div class="text-muted small">Duyệt bài viết và quản lý nội dung cộng đồng.</div>
    </div>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Tiêu đề</th>
                <th>Ngày tạo</th>
                <th>Duyệt</th>
                <th class="text-end"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.PostId</td>
                    <td class="fw-semibold">@p.Title</td>
                    <td>@p.CreatedDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (p.IsApproved)
                        {
                            <span class="badge bg-success-subtle text-success border border-success-subtle">
                                <i class="bi bi-check2-circle me-1"></i>Đã duyệt
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
                                <i class="bi bi-hourglass-split me-1"></i>Chờ duyệt
                            </span>
                        }
                    </td>
                    <td class="text-end">
                        @if (!p.IsApproved)
                        {
                            <form asp-action="ApprovePost" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@p.PostId" />
                                <button type="submit" class="btn btn-sm btn-outline-success">
                                    <i class="bi bi-check2 me-1"></i>Duyệt
                                </button>
                            </form>
                        }

                        <form asp-action="DeletePost"
                              method="post"
                              class="d-inline"
                              data-confirm-message="Xóa bài viết này? Thao tác không thể hoàn tác."
                              data-confirm-title="Xác nhận xóa"
                              data-confirm-ok="Xóa">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@p.PostId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash me-1"></i>Xóa
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Posts" asp-route-page="@(currentPage - 1)">
                    Trước
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Posts" asp-route-page="@i">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Posts" asp-route-page="@(currentPage + 1)">
                    Sau
                </a>
            </li>
        </ul>
    </nav>
}