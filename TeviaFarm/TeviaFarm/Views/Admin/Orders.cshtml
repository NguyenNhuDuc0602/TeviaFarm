@model IEnumerable<TeviaFarm.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

@functions {
    public string GetStatusText(string? status)
    {
        return status switch
        {
            "Pending" => "Chờ xử lý",
            "Shipping" => "Đang giao",
            "Completed" => "Hoàn tất",
            "Cancelled" => "Hủy",
            _ => status ?? ""
        };
    }
}

<h2 class="mb-3">Quản lý đơn hàng</h2>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Ngày đặt</th>
                <th>Trạng thái</th>
                <th>Tổng tiền</th>
                <th>Địa chỉ giao</th>
                <th class="text-end">Cập nhật</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td>@o.OrderId</td>
                    <td>@o.OrderDate</td>
                    <td>@GetStatusText(o.Status)</td>
                    <td>@o.TotalAmount.ToString("N0") đ</td>
                    <td>@o.ShippingAddress</td>
                    <td class="text-end">
                        <form asp-action="UpdateOrderStatus" method="post" class="d-flex justify-content-end gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@o.OrderId" />
                            <select name="status" class="form-select form-select-sm" style="max-width: 180px;">
                                <option value="Pending" selected="@(o.Status == "Pending")">Chờ xử lý</option>
                                <option value="Shipping" selected="@(o.Status == "Shipping")">Đang giao</option>
                                <option value="Completed" selected="@(o.Status == "Completed")">Hoàn tất</option>
                                <option value="Cancelled" selected="@(o.Status == "Cancelled")">Hủy</option>
                            </select>
                            <button type="submit" class="btn btn-sm btn-outline-primary">Lưu</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>