@model IEnumerable<TeviaFarm.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

@functions {
    public string GetStatusText(string? status)
    {
        return status switch
        {
            "Pending" => "Chờ xử lý",
            "PendingPayment" => "Chờ xác nhận thanh toán",
            "Shipping" => "Đang giao",
            "Completed" => "Hoàn tất",
            "Cancelled" => "Hủy",
            _ => status ?? ""
        };
    }

    public string GetStatusBadgeClass(string? status)
    {
        return status switch
        {
            "Pending" => "bg-warning-subtle text-warning border border-warning-subtle",
            "PendingPayment" => "bg-primary-subtle text-primary border border-primary-subtle",
            "Shipping" => "bg-info-subtle text-info border border-info-subtle",
            "Completed" => "bg-success-subtle text-success border border-success-subtle",
            "Cancelled" => "bg-danger-subtle text-danger border border-danger-subtle",
            _ => "bg-secondary-subtle text-secondary border border-secondary-subtle"
        };
    }

    public string GetPaymentMethodText(string? paymentMethod)
    {
        return paymentMethod switch
        {
            "COD" => "Thanh toán khi nhận hàng",
            "VnPay" => "VNPAY",
            "ChuyenKhoan" => "Chuyển khoản",
            _ => paymentMethod ?? ""
        };
    }

    public string GetGhtkStatusBadgeClass(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
            return "bg-secondary-subtle text-secondary border border-secondary-subtle";

        var s = status.Trim().ToLower();

        if (s.Contains("created") || s.Contains("success") || s.Contains("thành công"))
            return "bg-success-subtle text-success border border-success-subtle";

        if (s.Contains("failed") || s.Contains("error") || s.Contains("không") || s.Contains("sync failed"))
            return "bg-warning-subtle text-warning border border-warning-subtle";

        return "bg-info-subtle text-info border border-info-subtle";
    }
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Quản trị</a></li>
        <li class="breadcrumb-item active" aria-current="page">Đơn hàng</li>
    </ol>
</nav>

<div class="d-flex align-items-end justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h2 class="page-title mb-1">Quản lý đơn hàng</h2>
        <div class="text-muted small">Cập nhật trạng thái xử lý, xác nhận thanh toán và theo dõi giao hàng.</div>
    </div>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Mã đơn</th>
                    <th>Ngày đặt</th>
                    <th>Thanh toán</th>
                    <th>Trạng thái</th>
                    <th>Tổng tiền</th>
                    <th>Địa chỉ giao</th>
                    <th>Mã GHTK</th>
                    <th>Trạng thái GHTK</th>
                    <th class="text-end">Cập nhật</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td>@o.OrderId</td>
                        <td>@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div class="small fw-semibold">@GetPaymentMethodText(o.PaymentMethod)</div>
                        </td>
                        <td>
                            <span class="badge @GetStatusBadgeClass(o.Status)">@GetStatusText(o.Status)</span>
                        </td>
                        <td class="fw-semibold text-success">@o.TotalAmount.ToString("N0") đ</td>
                        <td>
                            <div>@o.ShippingAddress</div>

                            @if (!string.IsNullOrWhiteSpace(o.ShippingWard) ||
                                                    !string.IsNullOrWhiteSpace(o.ShippingDistrict) ||
                                                    !string.IsNullOrWhiteSpace(o.ShippingProvince))
                            {
                        <div class="text-muted small">
                            @string.Join(", ", new[] { o.ShippingWard, o.ShippingDistrict, o.ShippingProvince }
                                                        .Where(x => !string.IsNullOrWhiteSpace(x)))
                        </div>
                                                }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(o.GhtkLabel))
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle">
                                    @o.GhtkLabel
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">Chưa có</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(o.GhtkStatus))
                            {
                                <span class="badge @GetGhtkStatusBadgeClass(o.GhtkStatus)">
                                    @o.GhtkStatus
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">Chưa đồng bộ</span>
                            }
                        </td>
                        <td class="text-end">
                            <form asp-action="UpdateOrderStatus" method="post" class="d-flex justify-content-end gap-2 flex-wrap">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@o.OrderId" />

                                <select name="status" class="form-select form-select-sm" style="max-width: 220px;">
                                    <option value="Pending" selected="@(o.Status == "Pending")">Chờ xử lý</option>
                                    <option value="PendingPayment" selected="@(o.Status == "PendingPayment")">Chờ xác nhận thanh toán</option>
                                    <option value="Shipping" selected="@(o.Status == "Shipping")">Đang giao</option>
                                    <option value="Completed" selected="@(o.Status == "Completed")">Hoàn tất</option>
                                    <option value="Cancelled" selected="@(o.Status == "Cancelled")">Hủy</option>
                                </select>

                                <button type="submit" class="btn btn-sm btn-outline-success">
                                    <i class="bi bi-check2-circle me-1"></i>Lưu
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Orders" asp-route-page="@(currentPage - 1)">
                    Trước
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Orders" asp-route-page="@i">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Orders" asp-route-page="@(currentPage + 1)">
                    Sau
                </a>
            </li>
        </ul>
    </nav>
}