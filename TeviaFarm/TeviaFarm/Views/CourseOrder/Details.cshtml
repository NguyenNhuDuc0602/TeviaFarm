@model TeviaFarm.Models.CourseOrder
@{
    ViewData["Title"] = "Chi tiết đơn mua khóa học";
    var culture = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");

    string GetStatusText(string? status)
    {
        return status switch
        {
            "Pending" => "Chờ thanh toán",
            "Paid" => "Đã thanh toán",
            "Cancelled" => "Đã hủy",
            _ => status ?? ""
        };
    }
}

<h2>Chi tiết đơn mua khóa học</h2>

<div class="card shadow-sm mb-3">
    <div class="card-header">
        <strong>Thông tin đơn</strong>
    </div>
    <div class="card-body">
        <p><strong>Mã đơn:</strong> @Model.CourseOrderId</p>
        <p><strong>Trạng thái:</strong> @GetStatusText(Model.Status)</p>
        <p><strong>Phương thức thanh toán:</strong> @Model.PaymentMethod</p>
        <p><strong>Ngày tạo:</strong> @Model.CreatedDate</p>
        <p class="mb-0"><strong>Tổng tiền:</strong> @Model.TotalAmount.ToString("N0", culture) đ</p>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header">
        <strong>Khóa học trong đơn</strong>
    </div>
    <div class="card-body">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Khóa học</th>
                    <th>Giá</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.CourseOrderDetails)
                {
                    <tr>
                        <td>@item.Course?.Title</td>
                        <td>@item.Price.ToString("N0", culture) đ</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="d-flex gap-2">
    @if (Model.Status == "Pending")
    {
        <a asp-action="Checkout" asp-route-id="@Model.CourseOrderId" class="btn btn-success">Tiếp tục thanh toán</a>
    }

    <a asp-action="History" class="btn btn-outline-secondary">Lịch sử mua khóa học</a>
    <a asp-controller="Course" asp-action="MyCourses" class="btn btn-secondary">Khóa học của tôi</a>
</div>