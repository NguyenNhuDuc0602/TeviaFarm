@model TeviaFarm.Models.CourseOrder
@{
    ViewData["Title"] = "Thanh toán khóa học";
    var culture = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
}

<h2>Thanh toán khóa học</h2>

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<div class="row">
    <div class="col-lg-8">
        <h4>Khóa học trong đơn</h4>

        <table class="table">
            <thead>
                <tr>
                    <th>Khóa học</th>
                    <th>Giá</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.CourseOrderDetails)
                {
                    <tr>
                        <td>@item.Course?.Title</td>
                        <td>@item.Price.ToString("N0", culture) đ</td>
                    </tr>
                }
            </tbody>
        </table>

        <form asp-action="Checkout" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.CourseOrderId" />

            <div class="mb-3">
                <label class="form-label">Phương thức thanh toán</label>

                <div class="form-check">
                    <input class="form-check-input"
                           type="radio"
                           name="paymentMethod"
                           id="pmCod"
                           value="COD"
                           checked>
                    <label class="form-check-label" for="pmCod">
                        Thanh toán khi nhận hàng (COD)
                    </label>
                </div>

                <div class="form-check">
                    <input class="form-check-input"
                           type="radio"
                           name="paymentMethod"
                           id="pmBank"
                           value="ChuyenKhoan">
                    <label class="form-check-label" for="pmBank">
                        Chuyển khoản ngân hàng
                    </label>
                </div>
            </div>

            <button type="submit" class="btn btn-success btn-lg">Xác nhận thanh toán</button>
            <a asp-action="History" class="btn btn-link">Lịch sử mua khóa học</a>
        </form>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <strong>Tổng thanh toán</strong>
            </div>
            <div class="card-body">
                <p class="mb-0">
                    <strong>@Model.TotalAmount.ToString("N0", culture) đ</strong>
                </p>
            </div>
        </div>
    </div>
</div>