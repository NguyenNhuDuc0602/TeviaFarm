@model TeviaFarm.Models.CourseOrder
@{
    ViewData["Title"] = "Thanh toán khóa học";
    var culture = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Khóa học</a></li>
        <li class="breadcrumb-item active" aria-current="page">Thanh toán</li>
    </ol>
</nav>

<div class="d-flex align-items-end justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h2 class="page-title mb-1">Thanh toán khóa học</h2>
        <div class="text-muted small">Xác nhận thanh toán để được cấp quyền học.</div>
    </div>
</div>

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="table-card mb-4">
            <div class="p-3 p-lg-4 border-bottom">
                <div class="d-flex align-items-center justify-content-between">
                    <h3 class="h5 page-title mb-0">Khóa học trong đơn</h3>
                    <span class="badge bg-success-subtle text-success border border-success-subtle">
                        <i class="bi bi-collection-play me-1"></i>@(Model.CourseOrderDetails?.Count ?? 0) khóa
                    </span>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Khóa học</th>
                            <th class="text-end" style="width: 180px;">Giá</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.CourseOrderDetails)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    <i class="bi bi-play-circle text-success me-1"></i>@item.Course?.Title
                                </td>
                                <td class="text-end fw-bold text-success">@item.Price.ToString("N0", culture) đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="summary-card p-3 p-lg-4">
            <h3 class="h5 page-title mb-3">Phương thức thanh toán</h3>

            <form asp-action="Checkout" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.CourseOrderId" />

                <div class="row g-2 mb-3">
                    <div class="col-12">
                        <label class="w-100 border rounded-3 p-3 d-flex gap-2 align-items-start" style="cursor: pointer;">
                            <input class="form-check-input mt-1"
                                   type="radio"
                                   name="paymentMethod"
                                   value="VnPay"
                                   checked>
                            <span>
                                <span class="fw-semibold d-block">VNPAY</span>
                                <span class="text-muted small">Thanh toán trực tuyến qua cổng VNPAY</span>
                            </span>
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn btn-success btn-lg w-100">
                    <i class="bi bi-check2-circle me-1"></i>Tiếp tục thanh toán
                </button>

                <a asp-action="History" class="btn btn-link w-100 mt-2 text-decoration-none">
                    <i class="bi bi-clock-history me-1"></i>Lịch sử mua khóa học
                </a>
            </form>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="summary-card p-3 p-lg-4 position-sticky" style="top: 110px;">
            <h3 class="h5 page-title mb-3">Tổng thanh toán</h3>
            <div class="d-flex align-items-center justify-content-between">
                <span class="text-muted">Tổng cộng</span>
                <span class="fw-bold fs-5 text-success">@Model.TotalAmount.ToString("N0", culture) đ</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}