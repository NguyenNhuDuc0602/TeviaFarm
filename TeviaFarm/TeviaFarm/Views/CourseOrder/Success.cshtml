@model TeviaFarm.Models.CourseOrder
@{
    ViewData["Title"] = "Thanh toán khóa học thành công";
    var culture = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-action="History">Lịch sử mua khóa học</a></li>
        <li class="breadcrumb-item active" aria-current="page">Thành công</li>
    </ol>
</nav>

<div class="card card-hover mb-4">
    <div class="card-body p-4 p-lg-5">
        <div class="d-flex align-items-start gap-3">
            <div class="text-success fs-1"><i class="bi bi-check2-circle"></i></div>
            <div>
                <h2 class="page-title mb-1">Thanh toán khóa học thành công</h2>
                <div class="text-muted">Bạn đã thanh toán thành công và được cấp quyền học.</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="summary-card p-3 p-lg-4">
            <h3 class="h5 page-title mb-3">Thông tin đơn mua khóa học</h3>
            <div class="d-grid gap-2">
                <div class="d-flex justify-content-between gap-3">
                    <span class="text-muted">Mã đơn</span>
                    <span class="fw-semibold text-success">#@Model.CourseOrderId</span>
                </div>
                <div class="d-flex justify-content-between gap-3">
                    <span class="text-muted">Trạng thái</span>
                    <span class="fw-semibold">@Model.Status</span>
                </div>
                <div class="d-flex justify-content-between gap-3">
                    <span class="text-muted">Thanh toán</span>
                    <span class="fw-semibold">@Model.PaymentMethod</span>
                </div>
                <div class="d-flex justify-content-between gap-3">
                    <span class="text-muted">Ngày tạo</span>
                    <span class="fw-semibold">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <div class="d-flex justify-content-between gap-3">
                    <span class="text-muted">Tổng tiền</span>
                    <span class="fw-bold text-success">@Model.TotalAmount.ToString("N0", culture) đ</span>
                </div>
            </div>

            <div class="d-grid gap-2 mt-3">
                <a asp-controller="Course" asp-action="MyCourses" class="btn btn-success">
                    <i class="bi bi-mortarboard me-1"></i>Vào khóa học của tôi
                </a>
                <a asp-action="History" class="btn btn-outline-success">
                    <i class="bi bi-clock-history me-1"></i>Lịch sử mua khóa học
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="table-card">
            <div class="p-3 p-lg-4 border-bottom">
                <h3 class="h5 page-title mb-0">Khóa học đã mua</h3>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Khóa học</th>
                            <th class="text-end" style="width: 180px;">Giá</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.CourseOrderDetails)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    <i class="bi bi-play-circle text-success me-1"></i>@item.Course?.Title
                                </td>
                                <td class="text-end fw-semibold">@item.Price.ToString("N0", culture) đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>