@{
    ViewData["Title"] = "Trang chủ Tevia Farm";
}

<div class="row g-4">
    <!-- Cột trái: danh mục giống website thương mại -->
    <div class="col-md-3 mb-4">
        <div class="card card-hover">
            <div class="card-header bg-success text-white d-flex align-items-center justify-content-between">
                <span><i class="bi bi-grid-3x3-gap me-2"></i>Danh mục</span>
                <span class="badge bg-light text-success">Nổi bật</span>
            </div>
            <div class="list-group list-group-flush">
                <a asp-controller="Product" asp-action="Details" asp-route-id="1" class="list-group-item list-group-item-action d-flex align-items-center gap-2">
                    <i class="bi bi-bag-check text-success"></i><span>Thịt heo trà xanh</span>
                </a>
                <a asp-controller="Product" asp-action="Details" asp-route-id="3" class="list-group-item list-group-item-action d-flex align-items-center gap-2">
                    <i class="bi bi-box-seam text-success"></i><span>Sản phẩm chế biến</span>
                </a>
                <a asp-controller="Product" asp-action="Details" asp-route-id="5" class="list-group-item list-group-item-action d-flex align-items-center gap-2">
                    <i class="bi bi-leaf text-success"></i><span>Bột trà xanh & lá trà xanh</span>
                </a>
                <a asp-controller="Product" asp-action="Details" asp-route-id="6" class="list-group-item list-group-item-action d-flex align-items-center gap-2">
                    <i class="bi bi-droplet-half text-success"></i><span>Cám gạo & thức ăn phối trộn</span>
                </a>
                <a asp-controller="Course" asp-action="Index" class="list-group-item list-group-item-action d-flex align-items-center gap-2">
                    <i class="bi bi-mortarboard text-success"></i><span>Khóa học chăn nuôi</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Cột phải: banner quảng cáo + giới thiệu -->
    <div class="col-md-9">
        <!-- Slider quảng cáo sản phẩm -->
        <div id="homeCarousel"
             class="carousel slide mb-4"
             data-bs-ride="carousel"
             data-bs-interval="4000"
             data-bs-pause="false"
             data-bs-wrap="true">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#homeCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                <button type="button" data-bs-target="#homeCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
                <button type="button" data-bs-target="#homeCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
            </div>

            <div class="carousel-inner shadow-sm">
                <div class="carousel-item active">
                    <div class="carousel-bg carousel-bg-1 d-flex align-items-center">
                        <div class="p-4 text-white">
                            <h3>Ba rọi heo trà xanh</h3>
                            <p>Thịt heo sạch, thơm ngon từ mô hình chăn nuôi sử dụng bột trà xanh.</p>
                            <a class="btn btn-light btn-sm" asp-controller="Product" asp-action="Index">Mua ngay</a>
                        </div>
                    </div>
                </div>

                <div class="carousel-item">
                    <div class="carousel-bg carousel-bg-2 d-flex align-items-center">
                        <div class="p-4 text-white">
                            <h3>Bột & lá trà xanh</h3>
                            <p>Tối ưu khẩu phần ăn cho đàn heo với bột và lá trà xanh chất lượng.</p>
                            <a class="btn btn-light btn-sm" asp-controller="Product" asp-action="Index">Xem sản phẩm</a>
                        </div>
                    </div>
                </div>

                <div class="carousel-item">
                    <div class="carousel-bg carousel-bg-3 d-flex align-items-center">
                        <div class="p-4 text-white">
                            <h3>Khóa học chăn nuôi sạch</h3>
                            <p>Học mô hình heo trà xanh, quản lý trang trại và công thức thức ăn.</p>
                            <a class="btn btn-light btn-sm" asp-controller="Course" asp-action="Index">Xem khóa học</a>
                        </div>
                    </div>
                </div>
            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#homeCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>

            <button class="carousel-control-next" type="button" data-bs-target="#homeCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>

        <!-- Khối giới thiệu -->
        <div class="row align-items-center mb-4 g-4">
            <div class="col-md-7">
                <h1 class="display-6 fw-bold text-success page-title mb-2">Tevia Farm</h1>
                <p class="lead text-muted mb-3">
                    Nền tảng chăn nuôi heo trà xanh, kết nối người tiêu dùng và nông hộ.
                </p>
                <div class="d-grid gap-2">
                    <div class="d-flex align-items-start gap-2">
                        <i class="bi bi-check-circle-fill text-success mt-1"></i>
                        <span>Mua thịt heo và sản phẩm từ mô hình heo trà xanh</span>
                    </div>
                    <div class="d-flex align-items-start gap-2">
                        <i class="bi bi-check-circle-fill text-success mt-1"></i>
                        <span>Tối ưu khẩu phần với công cụ tính bột trà xanh</span>
                    </div>
                    <div class="d-flex align-items-start gap-2">
                        <i class="bi bi-check-circle-fill text-success mt-1"></i>
                        <span>Tham gia cộng đồng chia sẻ kinh nghiệm chăn nuôi</span>
                    </div>
                    <div class="d-flex align-items-start gap-2">
                        <i class="bi bi-check-circle-fill text-success mt-1"></i>
                        <span>Học chăn nuôi sạch qua các khóa học trực tuyến</span>
                    </div>
                </div>
                <div class="mt-3 d-flex flex-wrap gap-2">
                    <a class="btn btn-success" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-bag me-1"></i>Mua sản phẩm
                    </a>
                    <a class="btn btn-outline-success" asp-controller="Course" asp-action="Index">
                        <i class="bi bi-mortarboard me-1"></i>Xem khóa học
                    </a>
                </div>
            </div>
            <div class="col-md-5">
                <div class="summary-card p-4 card-hover">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h4 class="mb-0">Công cụ tính khẩu phần</h4>
                        <span class="badge bg-success-subtle text-success border border-success-subtle">
                            <i class="bi bi-lightning-charge-fill me-1"></i>Nhanh
                        </span>
                    </div>
                    <p class="text-muted mb-3">Tính nhanh tỷ lệ bột trà xanh và cám cho đàn heo của bạn.</p>
                    <a class="btn btn-success w-100" asp-controller="Tool" asp-action="FeedCalculator">
                        <i class="bi bi-calculator me-1"></i>Mở công cụ
                    </a>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <div class="card h-100 card-hover">
                    <div class="card-body">
                        <h5 class="card-title">Sản phẩm nổi bật</h5>
                        <p class="card-text text-muted">Ba rọi heo trà xanh, bột trà xanh nguyên chất, lá trà xanh phơi khô, cám gạo phối trộn...</p>
                        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-success btn-sm">
                            <i class="bi bi-arrow-right me-1"></i>Xem tất cả sản phẩm
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="card h-100 card-hover">
                    <div class="card-body">
                        <h5 class="card-title">Cộng đồng & khóa học</h5>
                        <p class="card-text text-muted">Chia sẻ công thức, kinh nghiệm chăn nuôi và học mô hình heo trà xanh qua các khóa học trực tuyến.</p>
                        <div class="d-flex flex-wrap gap-2">
                            <a asp-controller="Community" asp-action="Index" class="btn btn-outline-success btn-sm">
                                <i class="bi bi-people me-1"></i>Vào cộng đồng
                            </a>
                            <a asp-controller="Course" asp-action="Index" class="btn btn-outline-success btn-sm">
                                <i class="bi bi-play-circle me-1"></i>Xem khóa học
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>