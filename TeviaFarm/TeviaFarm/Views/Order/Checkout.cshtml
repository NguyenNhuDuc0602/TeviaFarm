@model TeviaFarm.Models.Cart
@{
    ViewData["Title"] = "Thanh toán";
    var orderTotal = Model.Items.Sum(i => (i.Product?.Price ?? 0) * i.Quantity);
    var culture = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
        <li class="breadcrumb-item active" aria-current="page">Thanh toán</li>
    </ol>
</nav>

<div class="d-flex align-items-end justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h2 class="page-title mb-1">Thanh toán</h2>
        <div class="text-muted small">Xác nhận đơn hàng và thông tin giao hàng.</div>
    </div>
</div>

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="table-card mb-4">
            <div class="p-3 p-lg-4 border-bottom">
                <div class="d-flex align-items-center justify-content-between">
                    <h3 class="h5 page-title mb-0">Tóm tắt đơn hàng</h3>
                    <span class="badge bg-success-subtle text-success border border-success-subtle">
                        <i class="bi bi-bag me-1"></i>@Model.Items.Count() sản phẩm
                    </span>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center" style="width: 110px;">Số lượng</th>
                            <th class="text-end" style="width: 180px;">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            var lineTotal = (item.Product?.Price ?? 0) * item.Quantity;
                            <tr>
                                <td class="fw-semibold">@item.Product?.ProductName</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end fw-bold text-success">@lineTotal.ToString("N0", culture) đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="summary-card p-3 p-lg-4">
            <h3 class="h5 page-title mb-3">Thông tin giao hàng</h3>

            <form asp-action="Checkout" method="post" id="checkoutForm">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-semibold">Tỉnh/Thành phố</label>
                    <select id="provinceSelect" class="form-select" required>
                        <option value="">-- Chọn tỉnh/thành --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Quận/Huyện</label>
                    <select id="districtSelect" class="form-select" required disabled>
                        <option value="">-- Chọn quận/huyện --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Phường/Xã</label>
                    <select id="wardSelect" class="form-select" required disabled>
                        <option value="">-- Chọn phường/xã --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Địa chỉ chi tiết</label>
                    <input id="detailAddress"
                           type="text"
                           class="form-control"
                           maxlength="150"
                           placeholder="Số nhà, tên đường..."
                           required />
                </div>

                <input type="hidden" id="shippingAddress" name="shippingAddress" />

                <div class="mb-3">
                    <div class="fw-semibold mb-2">Phương thức thanh toán</div>

                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="w-100 border rounded-3 p-3 d-flex gap-2 align-items-start" style="cursor: pointer;">
                                <input class="form-check-input mt-1"
                                       type="radio"
                                       name="paymentMethod"
                                       value="COD"
                                       checked>
                                <span>
                                    <span class="fw-semibold d-block">COD</span>
                                    <span class="text-muted small">Thanh toán khi nhận hàng</span>
                                </span>
                            </label>
                        </div>

                        <div class="col-md-6">
                            <label class="w-100 border rounded-3 p-3 d-flex gap-2 align-items-start" style="cursor: pointer;">
                                <input class="form-check-input mt-1"
                                       type="radio"
                                       name="paymentMethod"
                                       value="VnPay">
                                <span>
                                    <span class="fw-semibold d-block">VNPAY</span>
                                    <span class="text-muted small">Thanh toán trực tuyến qua cổng VNPAY</span>
                                </span>
                            </label>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-success btn-lg w-100">
                    <i class="bi bi-check2-circle me-1"></i>Xác nhận đặt hàng
                </button>
            </form>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="summary-card p-3 p-lg-4 position-sticky" style="top: 110px;">
            <h3 class="h5 page-title mb-3">Tổng đơn hàng</h3>

            <div class="d-flex align-items-center justify-content-between mb-2">
                <span class="text-muted">Tạm tính</span>
                <span class="fw-bold fs-5 text-success">@orderTotal.ToString("N0", culture) đ</span>
            </div>

            <div class="text-muted small">
                <i class="bi bi-truck me-1"></i>Miễn phí vận chuyển cho đơn trên 300.000 đ
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const API_BASE = "https://open.oapi.vn/location";

        const provinceSelect = document.getElementById("provinceSelect");
        const districtSelect = document.getElementById("districtSelect");
        const wardSelect = document.getElementById("wardSelect");
        const detailAddressInput = document.getElementById("detailAddress");
        const shippingAddressInput = document.getElementById("shippingAddress");
        const checkoutForm = document.getElementById("checkoutForm");

        async function loadProvinces() {
            try {
                provinceSelect.disabled = true;
                provinceSelect.innerHTML = '<option value="">Đang tải tỉnh/thành...</option>';

                const res = await fetch(`${API_BASE}/provinces?page=0&size=100`);
                if (!res.ok) {
                    throw new Error("Không tải được danh sách tỉnh/thành. HTTP " + res.status);
                }

                const result = await res.json();
                const provinces = result.data || [];

                provinceSelect.innerHTML = '<option value="">-- Chọn tỉnh/thành --</option>';

                if (!Array.isArray(provinces) || provinces.length === 0) {
                    provinceSelect.innerHTML = '<option value="">-- Không có dữ liệu tỉnh/thành --</option>';
                    provinceSelect.disabled = true;
                    return;
                }

                provinces.forEach(p => {
                    const option = document.createElement("option");
                    option.value = p.id;
                    option.textContent = p.name;
                    option.dataset.name = p.name;
                    provinceSelect.appendChild(option);
                });

                provinceSelect.disabled = false;
            } catch (error) {
                console.error("loadProvinces error:", error);
                provinceSelect.innerHTML = '<option value="">-- Không tải được tỉnh/thành --</option>';
                provinceSelect.disabled = true;
                alert("Không thể tải danh sách tỉnh/thành.");
            }
        }

        async function loadDistrictsByProvinceId(provinceId) {
            try {
                districtSelect.disabled = true;
                districtSelect.innerHTML = '<option value="">Đang tải quận/huyện...</option>';

                const res = await fetch(`${API_BASE}/districts/${provinceId}?page=0&size=100`);
                if (!res.ok) {
                    throw new Error("Không tải được danh sách quận/huyện. HTTP " + res.status);
                }

                const result = await res.json();
                const districts = result.data || [];

                districtSelect.innerHTML = '<option value="">-- Chọn quận/huyện --</option>';

                if (!Array.isArray(districts) || districts.length === 0) {
                    districtSelect.innerHTML = '<option value="">-- Không có quận/huyện --</option>';
                    districtSelect.disabled = true;
                    return;
                }

                districts.forEach(d => {
                    const option = document.createElement("option");
                    option.value = d.id;
                    option.textContent = d.name;
                    option.dataset.name = d.name;
                    districtSelect.appendChild(option);
                });

                districtSelect.disabled = false;
            } catch (error) {
                console.error("loadDistrictsByProvinceId error:", error);
                districtSelect.innerHTML = '<option value="">-- Không tải được quận/huyện --</option>';
                districtSelect.disabled = true;
                alert("Không thể tải danh sách quận/huyện.");
            }
        }

        async function loadWardsByDistrictId(districtId) {
            try {
                wardSelect.disabled = true;
                wardSelect.innerHTML = '<option value="">Đang tải phường/xã...</option>';

                const res = await fetch(`${API_BASE}/wards/${districtId}?page=0&size=100`);
                if (!res.ok) {
                    throw new Error("Không tải được danh sách phường/xã. HTTP " + res.status);
                }

                const result = await res.json();
                const wards = result.data || [];

                wardSelect.innerHTML = '<option value="">-- Chọn phường/xã --</option>';

                if (!Array.isArray(wards) || wards.length === 0) {
                    wardSelect.innerHTML = '<option value="">-- Không có phường/xã --</option>';
                    wardSelect.disabled = true;
                    return;
                }

                wards.forEach(w => {
                    const option = document.createElement("option");
                    option.value = w.id;
                    option.textContent = w.name;
                    option.dataset.name = w.name;
                    wardSelect.appendChild(option);
                });

                wardSelect.disabled = false;
            } catch (error) {
                console.error("loadWardsByDistrictId error:", error);
                wardSelect.innerHTML = '<option value="">-- Không tải được phường/xã --</option>';
                wardSelect.disabled = true;
                alert("Không thể tải danh sách phường/xã.");
            }
        }

        function buildShippingAddress() {
            const provinceName = provinceSelect.options[provinceSelect.selectedIndex]?.dataset.name || "";
            const districtName = districtSelect.options[districtSelect.selectedIndex]?.dataset.name || "";
            const wardName = wardSelect.options[wardSelect.selectedIndex]?.dataset.name || "";
            const detailAddress = detailAddressInput.value.trim();

            const fullAddress = [detailAddress, wardName, districtName, provinceName]
                .filter(x => x && x.trim() !== "")
                .join(", ");

            shippingAddressInput.value = fullAddress;
        }

        provinceSelect.addEventListener("change", async function () {
            const provinceId = this.value;

            districtSelect.innerHTML = '<option value="">-- Chọn quận/huyện --</option>';
            districtSelect.disabled = true;

            wardSelect.innerHTML = '<option value="">-- Chọn phường/xã --</option>';
            wardSelect.disabled = true;

            shippingAddressInput.value = "";

            if (!provinceId) {
                buildShippingAddress();
                return;
            }

            await loadDistrictsByProvinceId(provinceId);
            buildShippingAddress();
        });

        districtSelect.addEventListener("change", async function () {
            const districtId = this.value;

            wardSelect.innerHTML = '<option value="">-- Chọn phường/xã --</option>';
            wardSelect.disabled = true;

            shippingAddressInput.value = "";

            if (!districtId) {
                buildShippingAddress();
                return;
            }

            await loadWardsByDistrictId(districtId);
            buildShippingAddress();
        });

        wardSelect.addEventListener("change", buildShippingAddress);
        detailAddressInput.addEventListener("input", buildShippingAddress);

        checkoutForm.addEventListener("submit", function (e) {
            buildShippingAddress();

            if (!provinceSelect.value) {
                e.preventDefault();
                alert("Vui lòng chọn tỉnh/thành.");
                provinceSelect.focus();
                return;
            }

            if (!districtSelect.value) {
                e.preventDefault();
                alert("Vui lòng chọn quận/huyện.");
                districtSelect.focus();
                return;
            }

            if (!wardSelect.value) {
                e.preventDefault();
                alert("Vui lòng chọn phường/xã.");
                wardSelect.focus();
                return;
            }

            if (!detailAddressInput.value.trim()) {
                e.preventDefault();
                alert("Vui lòng nhập địa chỉ chi tiết.");
                detailAddressInput.focus();
                return;
            }

            if (!shippingAddressInput.value.trim()) {
                e.preventDefault();
                alert("Địa chỉ giao hàng không hợp lệ.");
                return;
            }
        });

        loadProvinces();
    </script>
}