@{
    var username = Context.Session.GetString("Username");
    var role = Context.Session.GetString("Role");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tevia Farm</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <!-- Thanh thông tin trên cùng -->
        <div class="bg-dark text-light py-1">
            <div class="container d-flex justify-content-between align-items-center small">
                <div>
                    Miễn phí vận chuyển cho đơn hàng trên 300.000 đ
                </div>
                <div>
                    Hỗ trợ: <strong>0989 000 000</strong> - <strong>cskh@teviafarm.vn</strong>
                </div>
            </div>
        </div>

        <!-- Header chính: logo + tìm kiếm + tài khoản/giỏ hàng -->
        <div class="border-bottom bg-white">
            <div class="container py-3 d-flex flex-wrap align-items-center justify-content-between">
                <a class="navbar-brand fw-bold text-success fs-3" asp-controller="Home" asp-action="Index">
                    Tevia Farm
                </a>

                <form class="flex-grow-1 mx-3" method="get" asp-controller="Product" asp-action="Index">
                    <div class="input-group">
                        <input type="text" name="search" class="form-control" placeholder="Tìm kiếm sản phẩm, bột trà xanh, cám gạo..." />
                        <button class="btn btn-success" type="submit">Tìm kiếm</button>
                    </div>
                </form>

                <div class="d-flex align-items-center">
                    <a asp-controller="Order" asp-action="History" class="me-3 text-decoration-none text-dark">
                        Tra cứu đơn hàng
                    </a>
                    <a asp-controller="Cart" asp-action="Index" class="me-3 text-decoration-none text-dark">
                        Giỏ hàng
                    </a>
                    @if (string.IsNullOrEmpty(username))
                    {
                        <a asp-controller="Account" asp-action="Login" class="text-decoration-none text-dark me-2">Đăng nhập</a>
                        <span class="text-muted">/</span>
                        <a asp-controller="Account" asp-action="Register" class="text-decoration-none text-dark ms-2">Đăng ký</a>
                    }
                    else
                    {
                        <span class="me-2">Xin chào, <strong>@username</strong></span>
                        <a asp-controller="Account" asp-action="Logout" class="text-decoration-none text-dark">Đăng xuất</a>
                    }
                </div>
            </div>
        </div>

        <!-- Thanh menu chính giống trang thương mại -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-success">
            <div class="container">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tool" asp-action="FeedCalculator">Công cụ chăn nuôi</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Community" asp-action="Index">Cộng đồng</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Course" asp-action="Index">Khóa học</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">Giới thiệu</a>
                        </li>
                        @if (string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">Quản trị</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="mt-4">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="bg-light border-top mt-5 py-4">
        <div class="container">
            <div class="row small">
                <div class="col-md-4 mb-3">
                    <h6 class="text-uppercase fw-bold">Tevia Farm</h6>
                    <p>Giải pháp chăn nuôi heo trà xanh sạch, hiệu quả và bền vững.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h6 class="text-uppercase fw-bold">Thông tin</h6>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="About" class="text-decoration-none text-muted">Giới thiệu</a></li>
                        <li><a asp-controller="Course" asp-action="Index" class="text-decoration-none text-muted">Khóa học</a></li>
                        <li><a asp-controller="Community" asp-action="Index" class="text-decoration-none text-muted">Cộng đồng</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h6 class="text-uppercase fw-bold">Liên hệ</h6>
                    <p class="mb-1">Hotline: 0989 000 000</p>
                    <p class="mb-1">Email: cskh@teviafarm.vn</p>
                    <p class="mb-0">Địa chỉ: Hà Nội, Việt Nam</p>
                </div>
            </div>
            <div class="text-center text-muted mt-3">
                &copy; @DateTime.Now.Year - Tevia Farm - Mô hình nuôi heo trà xanh
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>

