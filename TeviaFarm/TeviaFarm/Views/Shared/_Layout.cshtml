@using System.Security.Claims
@{
    var username = User.Identity?.Name;
    var isLoggedIn = User.Identity?.IsAuthenticated ?? false;
    var isAdmin = User.IsInRole("Admin");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tevia Farm</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="app-shell">
    <header>
        <div class="topbar">
            <div class="container topbar-inner">
                <div class="topbar-left">
                    Miễn phí vận chuyển cho đơn hàng trên 300.000 đ
                </div>
                <div class="topbar-right">
                    <span>Hotline: <strong>0989 000 000</strong></span>
                    <span class="topbar-sep">|</span>
                    <span>Email: <strong>cskh@teviafarm.vn</strong></span>
                </div>
            </div>
        </div>

        <div class="main-header">
            <div class="container">
                <div class="main-header-inner">
                    <a class="brand-wrap text-decoration-none" asp-controller="Home" asp-action="Index">
                        <img src="~/images/logo-teviafarm.jpg" alt="Tevia Farm Logo" class="brand-logo" />
                        <div class="brand-text">
                            <span class="brand-title">Tevia Farm</span>
                            <span class="brand-subtitle">Heo trà xanh sạch & bền vững</span>
                        </div>
                    </a>

                    <form class="header-search" method="get" asp-controller="Product" asp-action="Index">
                        <div class="input-group">
                            <input type="text"
                                   name="search"
                                   class="form-control search-input"
                                   placeholder="Tìm kiếm sản phẩm, bột trà xanh, cám gạo..." />
                            <button class="btn btn-success search-btn" type="submit">Tìm kiếm</button>
                        </div>
                    </form>

                    <div class="header-actions">
                        <a asp-controller="Order" asp-action="History" class="header-action-link">
                            Tra cứu đơn hàng
                        </a>
                        <a asp-controller="Cart" asp-action="Index" class="header-action-link">
                            Giỏ hàng
                        </a>

                        @if (!isLoggedIn)
                        {
                            <a asp-controller="Account" asp-action="Login" class="header-action-link">Đăng nhập</a>
                            <a asp-controller="Account" asp-action="Register" class="header-register-btn">Đăng ký</a>
                        }
                        else
                        {
                            <span class="header-user">Xin chào, <strong>@username</strong></span>
                            <a asp-controller="Account" asp-action="Logout" class="header-action-link">Đăng xuất</a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <nav class="navbar navbar-expand-lg navbar-dark main-nav">
            <div class="container">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 nav-menu-custom">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tool" asp-action="FeedCalculator">Công cụ chăn nuôi</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Community" asp-action="Index">Cộng đồng</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Course" asp-action="Index">Khóa học</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">Giới thiệu</a>
                        </li>

                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">Quản trị</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="mt-4 app-main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-top">
                <div class="row g-4">
                    <div class="col-lg-4 col-md-6">
                        <div class="footer-brand-block">
                            <div class="footer-brand-row">
                                <img src="~/images/logo-teviafarm.jpg" alt="Tevia Farm Logo" class="footer-logo" />
                                <div>
                                    <h5 class="footer-brand-title mb-1">Tevia Farm</h5>
                                    <p class="footer-brand-desc mb-0">
                                        Giải pháp chăn nuôi heo trà xanh sạch, hiệu quả và bền vững.
                                        Kết nối nông hộ, người tiêu dùng, cộng đồng và kiến thức thực tiễn.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-6">
                        <h6 class="footer-heading">Khám phá</h6>
                        <ul class="footer-links">
                            <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                            <li><a asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                            <li><a asp-controller="Course" asp-action="Index">Khóa học</a></li>
                            <li><a asp-controller="Community" asp-action="Index">Cộng đồng</a></li>
                        </ul>
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <h6 class="footer-heading">Hỗ trợ khách hàng</h6>
                        <ul class="footer-links">
                            <li><a asp-controller="Order" asp-action="History">Tra cứu đơn hàng</a></li>
                            <li><a asp-controller="Tool" asp-action="FeedCalculator">Công cụ khẩu phần</a></li>
                            <li><a asp-controller="Home" asp-action="About">Giới thiệu</a></li>
                            <li><a asp-controller="Account" asp-action="Register">Tạo tài khoản</a></li>
                        </ul>
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <h6 class="footer-heading">Liên hệ</h6>
                        <div class="footer-contact">
                            <p class="mb-2"><strong>Hotline:</strong> 0989 000 000</p>
                            <p class="mb-2"><strong>Email:</strong> cskh@teviafarm.vn</p>
                            <p class="mb-2"><strong>Địa chỉ:</strong> Hà Nội, Việt Nam</p>
                            <p class="mb-0"><strong>Giờ làm việc:</strong> 08:00 - 17:30, Thứ 2 - Thứ 7</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="footer-bottom">
                <div class="footer-bottom-inner">
                    <span>&copy; @DateTime.Now.Year - Tevia Farm. All rights reserved.</span>
                    <span class="footer-bottom-note">Mô hình nuôi heo trà xanh sạch cho nông nghiệp bền vững.</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const el = document.getElementById("homeCarousel");
            if (el) {
                new bootstrap.Carousel(el, {
                    interval: 4000,
                    ride: "carousel",
                    pause: false,
                    wrap: true,
                    touch: true
                });
            }
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>