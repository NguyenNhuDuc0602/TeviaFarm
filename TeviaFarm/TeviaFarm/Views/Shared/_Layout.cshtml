@using System.Security.Claims
@{
    var username = User.Identity?.Name;
    var isLoggedIn = User.Identity?.IsAuthenticated ?? false;
    var isAdmin = User.IsInRole("Admin");

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    string ActiveNav(string controller, string? action = null)
    {
        var controllerMatch = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
        if (!controllerMatch) return "";

        if (action == null) return "active";
        return string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tevia Farm</title>
    <meta name="theme-color" content="#157347" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-shell">
    <header class="site-header">
        <div class="topbar">
            <div class="container topbar-inner">
                <div class="topbar-left">
                    Miễn phí vận chuyển cho đơn hàng trên 300.000 đ
                </div>
                <div class="topbar-right">
                    <span>Hotline: <strong>0989 000 000</strong></span>
                    <span class="topbar-sep">|</span>
                    <span>Email: <strong>cskh@teviafarm.vn</strong></span>
                </div>
            </div>
        </div>

        <div class="main-header">
            <div class="container">
                <div class="main-header-inner">
                    <a class="brand-wrap text-decoration-none" asp-controller="Home" asp-action="Index">
                        <img src="~/images/logo-teviafarm.jpg" alt="Tevia Farm Logo" class="brand-logo" />
                        <div class="brand-text">
                            <span class="brand-title">Tevia Farm</span>
                            <span class="brand-subtitle">Heo trà xanh sạch & bền vững</span>
                        </div>
                    </a>

                    <form class="header-search" method="get" asp-controller="Product" asp-action="Index">
                        <div class="input-group">
                            <input type="text"
                                   name="search"
                                   class="form-control search-input"
                                   placeholder="Tìm kiếm sản phẩm, bột trà xanh, cám gạo..." />
                            <button class="btn btn-success search-btn" type="submit">Tìm kiếm</button>
                        </div>
                    </form>

                    <div class="header-actions">
                        <a asp-controller="Order" asp-action="History" class="header-action-link">
                            <i class="bi bi-receipt me-1"></i>Tra cứu đơn hàng
                        </a>
                        <a asp-controller="Cart" asp-action="Index" class="header-action-link">
                            <i class="bi bi-bag me-1"></i>Giỏ hàng
                        </a>

                        @if (!isLoggedIn)
                        {
                            <a asp-controller="Account" asp-action="Login" class="header-action-link">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
                            </a>
                            <a asp-controller="Account" asp-action="Register" class="header-register-btn">
                                <i class="bi bi-person-plus me-1"></i>Đăng ký
                            </a>
                        }
                        else
                        {
                            <span class="header-user">Xin chào, <strong>@username</strong></span>
                            <a asp-controller="Account" asp-action="Logout" class="header-action-link">
                                <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <nav class="navbar navbar-expand-lg navbar-dark main-nav">
            <div class="container">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 nav-menu-custom">
                        <li class="nav-item">
                            <a class="nav-link @ActiveNav("Home", "Index")" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @ActiveNav("Product")" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @ActiveNav("Tool", "FeedCalculator")" asp-controller="Tool" asp-action="FeedCalculator">Công cụ chăn nuôi</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @ActiveNav("Community")" asp-controller="Community" asp-action="Index">Cộng đồng</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @ActiveNav("Course")" asp-controller="Course" asp-action="Index">Khóa học</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @ActiveNav("Home", "About")" asp-controller="Home" asp-action="About">Giới thiệu</a>
                        </li>

                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link @ActiveNav("Admin")" asp-controller="Admin" asp-action="Index">Quản trị</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="app-main py-4">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-top">
                <div class="row g-4">
                    <div class="col-lg-4 col-md-6">
                        <div class="footer-brand-block">
                            <div class="footer-brand-row">
                                <img src="~/images/logo-teviafarm.jpg" alt="Tevia Farm Logo" class="footer-logo" />
                                <div>
                                    <h5 class="footer-brand-title mb-1">Tevia Farm</h5>
                                    <p class="footer-brand-desc mb-0">
                                        Giải pháp chăn nuôi heo trà xanh sạch, hiệu quả và bền vững.
                                        Kết nối nông hộ, người tiêu dùng, cộng đồng và kiến thức thực tiễn.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-6">
                        <h6 class="footer-heading">Khám phá</h6>
                        <ul class="footer-links">
                            <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                            <li><a asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                            <li><a asp-controller="Course" asp-action="Index">Khóa học</a></li>
                            <li><a asp-controller="Community" asp-action="Index">Cộng đồng</a></li>
                        </ul>
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <h6 class="footer-heading">Hỗ trợ khách hàng</h6>
                        <ul class="footer-links">
                            <li><a asp-controller="Order" asp-action="History">Tra cứu đơn hàng</a></li>
                            <li><a asp-controller="Tool" asp-action="FeedCalculator">Công cụ khẩu phần</a></li>
                            <li><a asp-controller="Home" asp-action="About">Giới thiệu</a></li>
                            <li><a asp-controller="Account" asp-action="Register">Tạo tài khoản</a></li>
                        </ul>
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <h6 class="footer-heading">Liên hệ</h6>
                        <div class="footer-contact">
                            <p class="mb-2"><strong>Hotline:</strong> 0989 000 000</p>
                            <p class="mb-2"><strong>Email:</strong> cskh@teviafarm.vn</p>
                            <p class="mb-2"><strong>Địa chỉ:</strong> Hà Nội, Việt Nam</p>
                            <p class="mb-0"><strong>Giờ làm việc:</strong> 08:00 - 17:30, Thứ 2 - Thứ 7</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="footer-bottom">
                <div class="footer-bottom-inner">
                    <span>&copy; @DateTime.Now.Year - Tevia Farm. All rights reserved.</span>
                    <span class="footer-bottom-note">Mô hình nuôi heo trà xanh sạch cho nông nghiệp bền vững.</span>
                </div>
            </div>
        </div>
    </footer>

    <!-- Toast -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080;">
        <div id="appToast"
             class="toast align-items-center text-bg-success border-0"
             role="alert"
             aria-live="assertive"
             aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body" id="appToastBody"></div>
                <button type="button"
                        class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"
                        aria-label="Close"></button>
            </div>
        </div>
    </div>

    <!-- Confirm Modal -->
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 18px;">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmModalTitle">Xác nhận</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="confirmModalBody">
                    Bạn có chắc chắn muốn thực hiện thao tác này?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-success" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-danger" id="confirmModalOk">Xác nhận</button>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["ToastMessage"] != null)
    {
        <div id="serverToastData"
             data-message="@TempData["ToastMessage"]"
             data-type="@(TempData["ToastType"] ?? "success")"
             class="d-none"></div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const el = document.getElementById("homeCarousel");
            if (el) {
                new bootstrap.Carousel(el, {
                    interval: 4000,
                    ride: "carousel",
                    pause: false,
                    wrap: true,
                    touch: true
                });
            }
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>