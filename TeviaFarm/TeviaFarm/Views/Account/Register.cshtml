@model TeviaFarm.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-9">
                <div class="auth-card">
                    <div class="row g-0">
                        <div class="col-lg-5 auth-aside p-4 p-lg-5">
                            <a class="text-decoration-none d-inline-flex align-items-center gap-2 mb-4"
                               asp-controller="Home" asp-action="Index">
                                <i class="bi bi-leaf-fill text-success"></i>
                                <span class="fw-bold text-success">Tevia Farm</span>
                            </a>

                            <h3 class="page-title mb-2">Tạo tài khoản</h3>
                            <p class="text-muted mb-0">
                                Nhận ưu đãi, lưu giỏ hàng và theo dõi lịch sử mua hàng, khóa học.
                            </p>

                            <div class="mt-4 d-grid gap-2 small">
                                <div class="d-flex align-items-start gap-2">
                                    <i class="bi bi-gift text-success mt-1"></i>
                                    <span>Ưu đãi và cập nhật sản phẩm mới</span>
                                </div>
                                <div class="d-flex align-items-start gap-2">
                                    <i class="bi bi-receipt text-success mt-1"></i>
                                    <span>Lịch sử đơn hàng rõ ràng</span>
                                </div>
                                <div class="d-flex align-items-start gap-2">
                                    <i class="bi bi-mortarboard text-success mt-1"></i>
                                    <span>Truy cập khóa học và cộng đồng</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-7 p-4 p-lg-5">
                            <h2 class="h4 page-title mb-3">Đăng ký tài khoản</h2>

                            <form asp-action="Register" method="post" novalidate>
                                @Html.AntiForgeryToken()

                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <div class="form-floating mb-2">
                                    <input asp-for="Username" class="form-control" placeholder="Tên đăng nhập" />
                                    <label asp-for="Username">Tên đăng nhập</label>
                                </div>
                                <div class="mb-3">
                                    <span asp-validation-for="Username" class="text-danger"></span>
                                </div>

                                <div class="form-floating mb-2">
                                    <input asp-for="Email" class="form-control" placeholder="Email" />
                                    <label asp-for="Email">Email</label>
                                </div>
                                <div class="mb-3">
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                                <div class="form-floating mb-2">
                                    <input asp-for="Password" class="form-control" placeholder="Mật khẩu" />
                                    <label asp-for="Password">Mật khẩu</label>
                                </div>
                                <div class="mb-3">
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>

                                <div class="form-floating mb-2">
                                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Xác nhận mật khẩu" />
                                    <label asp-for="ConfirmPassword">Xác nhận mật khẩu</label>
                                </div>
                                <div class="mb-3">
                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                </div>

                                <button type="submit" class="btn btn-success w-100">
                                    <i class="bi bi-person-plus me-1"></i>Đăng ký
                                </button>

                                <div class="text-center mt-3">
                                    <a asp-action="Login" class="text-decoration-none">
                                        Đã có tài khoản? <span class="fw-semibold">Đăng nhập</span>
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}